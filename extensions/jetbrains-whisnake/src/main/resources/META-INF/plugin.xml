<idea-plugin>
    <id>dev.begeistert.whisnake</id>
    <name>Whisnake</name>
    <version>0.0.1</version>
    <vendor email="begeistert@gmail.com" url="https://github.com/begeistert/pymcu">begeistert</vendor>

    <description><![CDATA[
        Whisnake support for PyCharm: run configurations, error highlighting, tool window,
        status bar chip indicator, and automatic project sync for pymcu projects.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.python</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Application-level settings service -->
        <applicationService
            serviceImplementation="dev.begeistert.whisnake.settings.WhisnakeSettings"/>

        <!-- Notification group used by WhisnakeStartupActivity -->
        <notificationGroup id="Whisnake" displayType="BALLOON" isLogByDefault="true"/>


        <!-- Status bar widget factory -->
        <statusBarWidgetFactory
            id="WhisnakeStatusBarWidget"
            implementation="dev.begeistert.whisnake.statusbar.WhisnakeStatusBarWidgetFactory"
            order="last"/>

        <!-- Tool window -->
        <toolWindow
            id="Whisnake"
            anchor="bottom"
            factoryClass="dev.begeistert.whisnake.toolwindow.WhisnakeToolWindowFactory"
            icon="/icons/whisnake.svg"/>

        <!-- Run configuration type -->
        <configurationType
            implementation="dev.begeistert.whisnake.run.WhisnakeRunConfigurationType"/>

        <!-- Console filter provider for compiler diagnostics -->
        <consoleFilterProvider
            implementation="dev.begeistert.whisnake.console.WhisnakeConsoleFilterProvider"/>

        <!-- Settings configurable under Tools -->
        <applicationConfigurable
            parentId="tools"
            instance="dev.begeistert.whisnake.settings.WhisnakeSettingsConfigurable"
            id="dev.begeistert.whisnake.settings.WhisnakeSettingsConfigurable"
            displayName="Whisnake"/>

        <!-- New Project wizard entry -->
        <directoryProjectGenerator
            implementation="dev.begeistert.whisnake.newproject.WhisnakeProjectGenerator"/>

        <!-- Extra library roots: pymcu_circuitpython/ and pymcu_micropython/ dirs
             so PyCharm resolves 'import digitalio', 'import machine', 'import board' -->
        <additionalLibraryRootsProvider
            implementation="dev.begeistert.whisnake.resolver.WhisnakeAdditionalLibraryRootsProvider"/>

    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <runConfigurationProducer
            implementation="dev.begeistert.whisnake.run.WhisnakeRunConfigurationProducer"
            order="last"/>
    </extensions>

    <!-- Project-open hook: fires reliably in PyCharm Community 2024.3 -->
    <applicationListeners>
        <listener
            class="dev.begeistert.whisnake.startup.WhisnakeStartupActivity"
            topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </applicationListeners>

</idea-plugin>
