<idea-plugin>
    <id>dev.begeistert.whipsnake</id>
    <name>Whipsnake</name>
    <version>0.1.0a1</version>
    <vendor email="begeistert@gmail.com" url="https://github.com/begeistert/whipsnake">begeistert</vendor>

    <description><![CDATA[
        Whipsnake support for PyCharm: run configurations, error highlighting, tool window,
        status bar chip indicator, and automatic project sync for Whipsnake projects.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.python</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Application-level settings service -->
        <applicationService
            serviceImplementation="dev.begeistert.whipsnake.settings.WhipsnakeSettings"/>

        <!-- Notification group used by WhipsnakeStartupActivity -->
        <notificationGroup id="Whipsnake" displayType="BALLOON" isLogByDefault="true"/>


        <!-- Status bar widget factory -->
        <statusBarWidgetFactory
            id="WhipsnakeStatusBarWidget"
            implementation="dev.begeistert.whipsnake.statusbar.WhipsnakeStatusBarWidgetFactory"
            order="last"/>

        <!-- Tool window -->
        <toolWindow
            id="Whipsnake"
            anchor="bottom"
            factoryClass="dev.begeistert.whipsnake.toolwindow.WhipsnakeToolWindowFactory"
            icon="/icons/whipsnake.svg"/>

        <!-- Run configuration type -->
        <configurationType
            implementation="dev.begeistert.whipsnake.run.WhipsnakeRunConfigurationType"/>

        <!-- Console filter provider for compiler diagnostics -->
        <consoleFilterProvider
            implementation="dev.begeistert.whipsnake.console.WhipsnakeConsoleFilterProvider"/>

        <!-- Settings configurable under Tools -->
        <applicationConfigurable
            parentId="tools"
            instance="dev.begeistert.whipsnake.settings.WhipsnakeSettingsConfigurable"
            id="dev.begeistert.whipsnake.settings.WhipsnakeSettingsConfigurable"
            displayName="Whipsnake"/>

        <!-- New Project wizard entry -->
        <directoryProjectGenerator
            implementation="dev.begeistert.whipsnake.newproject.WhipsnakeProjectGenerator"/>

        <!-- Extra library roots: whipsnake_circuitpython/ and whipsnake_micropython/ dirs
             so PyCharm resolves 'import digitalio', 'import machine', 'import board' -->
        <additionalLibraryRootsProvider
            implementation="dev.begeistert.whipsnake.resolver.WhipsnakeAdditionalLibraryRootsProvider"/>

    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <runConfigurationProducer
            implementation="dev.begeistert.whipsnake.run.WhipsnakeRunConfigurationProducer"
            order="last"/>
    </extensions>

    <!-- Project-open hook: fires reliably in PyCharm Community 2024.3 -->
    <applicationListeners>
        <listener
            class="dev.begeistert.whipsnake.startup.WhipsnakeStartupActivity"
            topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </applicationListeners>

</idea-plugin>
