<idea-plugin>
    <id>dev.begeistert.pymcu</id>
    <name>PyMCU</name>
    <version>0.1.0a1</version>
    <vendor email="begeistert@gmail.com" url="https://pymcu.dev">begeistert</vendor>

    <description><![CDATA[
        PyMCU support for PyCharm: run configurations, error highlighting, tool window,
        status bar chip indicator, and automatic project sync for PyMCU projects.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.python</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Application-level settings service -->
        <applicationService
            serviceImplementation="dev.begeistert.pymcu.settings.PyMCUSettings"/>

        <!-- Notification group used by PyMCUStartupActivity -->
        <notificationGroup id="PyMCU" displayType="BALLOON" isLogByDefault="true"/>


        <!-- Status bar widget factory -->
        <statusBarWidgetFactory
            id="PyMCUStatusBarWidget"
            implementation="dev.begeistert.pymcu.statusbar.PyMCUStatusBarWidgetFactory"
            order="last"/>

        <!-- Tool window -->
        <toolWindow
            id="PyMCU"
            anchor="bottom"
            factoryClass="dev.begeistert.pymcu.toolwindow.PyMCUToolWindowFactory"
            icon="/icons/pymcu.svg"/>

        <!-- Run configuration type -->
        <configurationType
            implementation="dev.begeistert.pymcu.run.PyMCURunConfigurationType"/>

        <!-- Console filter provider for compiler diagnostics -->
        <consoleFilterProvider
            implementation="dev.begeistert.pymcu.console.PyMCUConsoleFilterProvider"/>

        <!-- Settings configurable under Tools -->
        <applicationConfigurable
            parentId="tools"
            instance="dev.begeistert.pymcu.settings.PyMCUSettingsConfigurable"
            id="dev.begeistert.pymcu.settings.PyMCUSettingsConfigurable"
            displayName="PyMCU"/>

        <!-- New Project wizard entry -->
        <directoryProjectGenerator
            implementation="dev.begeistert.pymcu.newproject.PyMCUProjectGenerator"/>

        <!-- Extra library roots: pymcu_circuitpython/ and pymcu_micropython/ dirs
             so PyCharm resolves 'import digitalio', 'import machine', 'import board' -->
        <additionalLibraryRootsProvider
            implementation="dev.begeistert.pymcu.resolver.PyMCUAdditionalLibraryRootsProvider"/>

    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <runConfigurationProducer
            implementation="dev.begeistert.pymcu.run.PyMCURunConfigurationProducer"
            order="last"/>
    </extensions>

    <!-- Project-open hook: fires reliably in PyCharm Community 2024.3 -->
    <applicationListeners>
        <listener
            class="dev.begeistert.pymcu.startup.PyMCUStartupActivity"
            topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </applicationListeners>

</idea-plugin>
